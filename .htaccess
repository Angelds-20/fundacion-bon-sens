# Fundación Bon Sens - Configuración Apache
# Activar: a2enmod rewrite headers

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Bloquear solicitudes HTTP directas a archivos del backend, instaladores y archivos de configuración
    RewriteCond %{THE_REQUEST} \s/backend/ [NC,OR]
    RewriteCond %{THE_REQUEST} \s/router\.php [NC,OR]
    RewriteCond %{THE_REQUEST} \s/Dockerfile [NC,OR]
    RewriteCond %{THE_REQUEST} \s/docker-compose [NC,OR]
    RewriteCond %{THE_REQUEST} \s/fly\.toml [NC,OR]
    RewriteCond %{THE_REQUEST} \s/entrypoint\.sh [NC,OR]
    RewriteCond %{THE_REQUEST} \s/start\.sh [NC,OR]
    RewriteCond %{THE_REQUEST} \s/README\.md [NC,OR]
    RewriteCond %{THE_REQUEST} \s/DOCUMENTACION\.md [NC]
    RewriteRule ^ - [F,L]

    # API routes
    RewriteRule ^api/(.*)$ backend/api.php [QSA,L,E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Admin SPA - rutas internas
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} ^/admin
    RewriteRule ^(.*)$ admin/index.html [QSA,L]

    # Reglas para URLs limpias de las páginas principales
    RewriteRule ^nosotros$ nosotros.html [L]
    RewriteRule ^que-hacemos$ que-hacemos.html [L]
    RewriteRule ^noticias$ noticias.html [L]
    RewriteRule ^como-ayudar$ como-ayudar.html [L]
    RewriteRule ^contacto$ contacto.html [L]

    # Regla para detalle de noticias (cualquier ruta bajo /noticias/algo)
    RewriteRule ^noticias/([a-z0-9-]+)$ noticia.html [L]

</IfModule>

<IfModule mod_headers.c>
    # Seguridad
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https://images.unsplash.com https://plus.unsplash.com https://picsum.photos; frame-src 'self' https://www.google.com https://maps.google.com; child-src 'self' blob: https://www.google.com https://maps.google.com; worker-src 'self' blob:;"

    # Cache para archivos estáticos (7 días)
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|woff2?)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/json application/javascript image/svg+xml
</IfModule>

# Denegar acceso a archivos sensibles, logs, configuraciones e infraestructura
<FilesMatch "^\.|\.(env|sqlite|db|log|yml|toml|sh|md|json)$">
    Require all denied
</FilesMatch>

<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>
