# ============================================
# Fundación Bon Sens - Configuración de Entorno
# ============================================
# Copia este archivo como .env y completa los valores

# Puerto del servidor
PORT=3000

# URL base (cambiar en producción)
BASE_URL=http://localhost:3000

# ============================================
# Administración
# ============================================
# Cambia esta contraseña en producción
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiame_segura_123
# Secreto para sesiones JWT/admin
SESSION_SECRET=genera_un_secreto_aleatorio_aqui

# ============================================
# Email (Nodemailer - opcional)
# ============================================
# SMTP para notificaciones de contacto
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contrasena-app
# Email al que llegarán las notificaciones
NOTIFICATION_EMAIL=contacto@fundacionbonsens.cl

# ============================================
# Base de Datos
# ============================================
DB_PATH=./data/bonsens.db
